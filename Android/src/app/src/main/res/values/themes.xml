<resources xmlns:tools="http://schemas.android.com/tools">
  <style name="Theme.Gallery" parent="android:Theme.Material.Light.NoActionBar" />
  <!-- Translucent theme for the Gemma assistant popup so the underlying app stays visible. -->
  <style name="Theme.OkGemma.Assistant" parent="android:Theme.Material.Light.NoActionBar">
      <item name="android:windowIsTranslucent">true</item>
      <item name="android:windowBackground">@android:color/transparent</item>
      <item name="android:windowContentOverlay">@null</item>
      <item name="android:windowNoTitle">true</item>
      <item name="android:backgroundDimEnabled">false</item>
      <item name="android:windowAnimationStyle">@android:style/Animation.Translucent</item>
  </style>
  <style name="Theme.Gallery.SplashScreen" parent="Theme.SplashScreen">
      <!-- Need to match surfaceLight in Colors.kt -->
      <item name="windowSplashScreenBackground">#FFFFFFFF</item>
      <item name="windowSplashScreenAnimatedIcon">@drawable/splash_logo</item>
      <item name="postSplashScreenTheme">@style/Theme.Gallery</item>
  </style>
  <style name="Theme.Gallery.OssLicenses" parent="Theme.AppCompat.Light.DarkActionBar">
      <item name="android:windowOptOutEdgeToEdgeEnforcement" tools:targetApi="35">true</item>
  </style>
</resources>